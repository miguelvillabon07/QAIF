# ═══════════════════════════════════════════════════════════════════
# MCP QA AUTOMATION — Variables de Entorno (Template)
#
# USO:
#   cp .env.example .env
#   Editar .env con tus valores reales
#
# IMPORTANTE:
#   - .env está en .gitignore → NUNCA lo subas a Git
#   - Guía completa de credenciales: docs/credentials_guide.md
# ═══════════════════════════════════════════════════════════════════


# ── LLM Provider ─────────────────────────────────────────────────
# "local"      → Qwen3:8b via Ollama (GPU, gratis, sin internet)
# "anthropic"  → Claude Sonnet 4 (API de pago, 200K contexto)
# Cambiar en runtime: escribir "model switch local" en la consola
LLM_PROVIDER=local

# Modelo Ollama (se descarga automáticamente al iniciar Docker)
# Opciones para 6GB VRAM: qwen3:8b | llama3.1:8b | mistral:7b
LOCAL_MODEL_NAME=qwen3:8b

# URL de Ollama — usar "ollama" dentro de Docker, "localhost" fuera
OLLAMA_BASE_URL=http://ollama:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1  # ← si corres fuera de Docker


# ── Anthropic Claude (solo si LLM_PROVIDER=anthropic) ───────────
# Obtener en: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR_CON_TU_KEY
ANTHROPIC_MODEL=claude-sonnet-4-5


# ── Google Drive ─────────────────────────────────────────────────
# Necesario para: extract <file_id>  (leer transcripciones)
# Guía paso a paso: docs/credentials_guide.md → Sección 3
#
# Pasos resumidos:
#   1. console.cloud.google.com → Crear proyecto
#   2. Habilitar "Google Drive API"
#   3. IAM → Service Accounts → Crear → Descargar JSON
#   4. Mover JSON a secrets/service_account.json
#   5. Compartir carpeta Drive con el email del Service Account
GOOGLE_SERVICE_ACCOUNT_JSON=secrets/service_account.json
# Para Docker (ruta dentro del contenedor):
# GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/service_account.json

# ID de la carpeta Drive con las transcripciones
# Obtener de la URL: drive.google.com/drive/folders/<ESTE_ES_EL_ID>
GOOGLE_DRIVE_FOLDER_ID=REEMPLAZAR_CON_ID_DE_TU_CARPETA


# ── Jira Cloud ───────────────────────────────────────────────────
# Necesario para: story create | report upload <issue>
# Guía paso a paso: docs/credentials_guide.md → Sección 4
#
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
#   → "Create API token" → copiar (solo visible una vez)
JIRA_URL=https://TU-EMPRESA.atlassian.net
JIRA_EMAIL=tu@email.com
JIRA_API_TOKEN=ATATT3xFfGF_REEMPLAZAR_CON_TU_TOKEN
JIRA_PROJECT_KEY=PROJ
# Epic padre (opcional — dejar vacío si no tienes)
JIRA_EPIC_KEY=


# ── Redis / CAG (Cache-Augmented Generation) ─────────────────────
# Redis corre en Docker — no requiere credenciales externas
# "redis" dentro de Docker, "localhost" fuera
REDIS_URL=redis://redis:6379
# REDIS_URL=redis://localhost:6379  # ← si corres fuera de Docker
REDIS_PASSWORD=
CAG_ENABLED=true
# TTLs en segundos (cuánto tiempo se cachea cada tipo de contexto)
CAG_README_TTL_SECONDS=3600      # 1 hora
CAG_API_SPEC_TTL_SECONDS=7200    # 2 horas
CAG_JIRA_CONFIG_TTL_SECONDS=1800 # 30 minutos


# ── LangGraph Checkpointing ──────────────────────────────────────
# SQLite para dev (no requiere setup adicional)
LANGGRAPH_CHECKPOINT_DB=sqlite:///checkpoints.db
# PostgreSQL para producción:
# LANGGRAPH_CHECKPOINT_DB=postgresql://user:pass@host/dbname


# ── LangSmith (opcional — trazas de agentes en la nube) ─────────
# Obtener en: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=mcp-qa-automation


# ── Pipeline ─────────────────────────────────────────────────────
# Máximo de reintentos para errores de red en run_api_tests
PIPELINE_RETRY_MAX=3
PIPELINE_RETRY_BACKOFF_BASE=2.0
# Si true, pausa antes de crear issues en Jira para revisión humana
HUMAN_REVIEW_ENABLED=false
HUMAN_REVIEW_TIMEOUT_SECONDS=300


# ── Reportes ─────────────────────────────────────────────────────
REPORT_OUTPUT_DIR=workspace/reports
REPORT_COMPANY_NAME=Mi Empresa S.A.
AUDIT_LOG_DIR=workspace/logs


# ── Git Workspace ────────────────────────────────────────────────
GIT_WORKSPACE_PATH=workspace/repos
GIT_DEFAULT_BRANCH=main


# ── Logging ──────────────────────────────────────────────────────
# INFO  → producción (JSON estructurado)
# DEBUG → desarrollo (verbose, consola legible)
LOG_LEVEL=INFO
